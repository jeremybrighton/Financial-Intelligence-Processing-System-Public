# ─────────────────────────────────────────────────────────────────────────────
# FRC System — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Financial Intelligence Processing System"
APP_VERSION="1.0.0"
ENVIRONMENT=development        # development | staging | production
DEBUG=false

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Use the same MongoDB Atlas cluster as the ML backend.
# The FRC system uses the 'frc_db' database — separate from 'fraud_detection'.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
FRC_DB_NAME=frc_db

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_KEY_AT_LEAST_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email / OTP ────────────────────────────────────────────────────────────────
SENDER_EMAIL=your-frc-email@gmail.com
SENDER_PASSWORD=your-gmail-app-password
OTP_EXPIRY_MINUTES=5

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add the FRC frontend domain when it is deployed.
CORS_ORIGINS=https://fraud-detector-b.vercel.app,http://localhost:3000,http://localhost:3001

# ── Policy Engine Defaults ─────────────────────────────────────────────────────
DEFAULT_CTR_THRESHOLD_USD=15000.0
DEFAULT_CBT_THRESHOLD_USD=10000.0
DEFAULT_SAR_ML_THRESHOLD=0.70

# ── Case Numbering ─────────────────────────────────────────────────────────────
CASE_NUMBER_PREFIX=FRC
CASE_NUMBER_YEAR=2026

# ── Report Export ──────────────────────────────────────────────────────────────
REPORT_EXPORT_DIR=/tmp/frc_reports
LEGAL_DATA_DIR=legal/structured
