# ─────────────────────────────────────────────────────────────────────────────
# Financial Intelligence Processing System — Environment Variables
# Copy to .env for local dev. Set in Render dashboard for production.
# Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME="Financial Intelligence Processing System"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=frc_db

# JWT
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Email / OTP (optional for MVP)
SENDER_EMAIL=
SENDER_PASSWORD=
OTP_EXPIRY_MINUTES=5

# Case numbering
CASE_NUMBER_PREFIX=FRC
CASE_NUMBER_YEAR=2026
