# ─────────────────────────────────────────────────────────────────────────────
# Financial Intelligence Processing System — Environment Variables
# Copy to .env for local dev. Set in Render dashboard for production.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Financial Intelligence Processing System"
APP_VERSION="1.0.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=false
API_V1_PREFIX=/api/v1

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Connect your application
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://REPLACE_USER:REPLACE_PASSWORD@REPLACE_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=frc_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Add FRC frontend domain when deployed.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Institution API Key header name ──────────────────────────────────────────
INSTITUTION_API_KEY_HEADER_NAME=X-Institution-API-Key

# ── Email / OTP (optional for MVP) ───────────────────────────────────────────
SENDER_EMAIL=
SENDER_PASSWORD=
OTP_EXPIRY_MINUTES=5

# ── Case / Report / Referral numbering ───────────────────────────────────────
CASE_NUMBER_PREFIX=FRC
CASE_NUMBER_YEAR=2026
